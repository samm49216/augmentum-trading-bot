# ============================================================================
#  Public Trading Bot — configuration
#  Copy to `.env` and fill in. NEVER commit the real .env (it holds credentials).
# ============================================================================

# --- Public.com credentials (the ACCOUNT OWNER generates these; keep secret) ---
API_SECRET_KEY=
DEFAULT_ACCOUNT_NUMBER=
TOKEN_VALIDITY_MINUTES=15          # SDK access-token lifetime (5–1440)

# --- Master safety switch --------------------------------------------------
#  true  = never places orders (logs intended orders only)  <-- keep here until validated
#  false = LIVE trading. Only the account owner should flip this.
DRY_RUN=true

# --- Risk guardrails (all fail CLOSED — missing/empty = block) --------------
# Comments are on their OWN lines here: an inline "# ..." after a value can be read
# as PART of the value by some python-dotenv versions, which would defeat the
# "empty allowlist = block everything" guarantee. Keep values bare.

# Optional account-wide ticker restriction, comma-separated (e.g. BTC,ETH,SPY).
# EMPTY = no restriction, every symbol allowed. (Per-bot ticker limits are set from
# the dashboard/chat; dollar caps + approvals below still bound risk regardless.)
SYMBOL_ALLOWLIST=
# Max $ per single order
MAX_ORDER_NOTIONAL=250
# Max $ notional placed per calendar day
MAX_DAILY_NOTIONAL=1000
# PDT guard: <4 day trades / 5 days for margin accounts under $25k (stocks/options)
MAX_DAY_TRADES=3
# Block new orders after this realized loss for the day ($)
DAILY_LOSS_LIMIT=100
# Block new orders if portfolio equity falls below this ($)
ACCOUNT_EQUITY_FLOOR=0

# --- Moore Platform dashboard (leave blank to run standalone) ----------------
PLATFORM_URL=https://moore-client-platform.netlify.app   # the shared dashboard
BOT_TOKEN=                         # YOUR per-client bot token (from your onboarding email)

# --- Your own AI for the natural-language assistant (optional) ---------------
ANTHROPIC_API_KEY=                 # YOUR key — your AI generates suggestions locally
ANTHROPIC_MODEL=claude-opus-4-8    # override to claude-sonnet-4-6 / claude-haiku-4-5 to cut cost
