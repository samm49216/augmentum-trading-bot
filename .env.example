# ============================================================================
#  Public Trading Bot — configuration
#  Copy to `.env` and fill in. NEVER commit the real .env (it holds credentials).
# ============================================================================

# --- Public.com credentials (the ACCOUNT OWNER generates these; keep secret) ---
API_SECRET_KEY=
DEFAULT_ACCOUNT_NUMBER=
TOKEN_VALIDITY_MINUTES=15          # SDK access-token lifetime (5–1440)

# --- Master safety switch --------------------------------------------------
#  true  = never places orders (logs intended orders only)  <-- keep here until validated
#  false = LIVE trading. Only the account owner should flip this.
DRY_RUN=true

# --- Risk guardrails (all fail CLOSED — missing/empty = block) --------------
SYMBOL_ALLOWLIST=                  # comma-separated, e.g. BTC,ETH,SPY. EMPTY = block everything.
MAX_ORDER_NOTIONAL=250             # max $ per single order
MAX_DAILY_NOTIONAL=1000            # max $ notional placed per calendar day
MAX_DAY_TRADES=3                   # PDT guard: <4 day trades / 5 days for margin accts under $25k (stocks/options)
DAILY_LOSS_LIMIT=100               # block new orders after this realized loss for the day ($)
ACCOUNT_EQUITY_FLOOR=0             # block new orders if portfolio equity falls below this ($)
